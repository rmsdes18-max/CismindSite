# EmailJS Configuration (https://www.emailjs.com/)
VITE_EMAILJS_SERVICE_ID=service_abc123
VITE_EMAILJS_TEMPLATE_ID=template_xyz789
VITE_EMAILJS_PUBLIC_KEY=aBcDeFgHiJkLmNoP

# Admin password hash (SHA-256) — nu pune parola în clar, doar hash-ul
# Generează: echo -n "parola_ta" | shasum -a 256
VITE_ADMIN_PASSWORD_HASH=<sha256_hash_here>

# FTP Deployment
FTP_HOST=ftp.cismind.ro
FTP_USER=cismind@cismind.ro
FTP_PASS=your_ftp_password
FTP_PORT=21
FTP_REMOTE_DIR=/
